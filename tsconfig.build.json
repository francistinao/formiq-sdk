{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "noEmit": false,
    "declarationMap": false,
    "stripInternal": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": [
    "src/router.tsx",
    "src/routeTree.gen.ts",
    "src/routes/**",
    "src/components/Footer.tsx",
    "src/components/Header.tsx",
    "src/components/ThemeToggle.tsx"
  ]
}
